# api-service (dev) 환경 변수 예시 — 실제 비밀값 금지(복사 후 채우기)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# DB (dev: 단일 노드, 로컬)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rag_api_dev
DB_USER=rag_api
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenSearch (dev: 단일 노드, 보안 완화)
OPENSEARCH_URL=http://localhost:9200

# Retrieval 서비스
RETRIEVAL_SERVICE_URL=http://localhost:8000

# dev: verbose 로깅 (JVM 원격 디버그는 Dockerfile 5005 포트)
LOG_LEVEL=DEBUG
