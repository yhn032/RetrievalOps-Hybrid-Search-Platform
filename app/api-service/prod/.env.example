# api-service (prod) 환경 변수 예시 — 실제 비밀값 금지(시크릿 매니저 권장)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# DB (prod 호스트)
DB_HOST=mariadb.prod.internal
DB_PORT=3306
DB_NAME=rag_api
DB_USER=rag_api
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=redis.prod.internal
REDIS_PORT=6379

# OpenSearch (prod: 보안 활성 https)
OPENSEARCH_URL=https://opensearch.prod.internal:9200

# Retrieval 서비스
RETRIEVAL_SERVICE_URL=https://retrieval.prod.internal:8000

# prod: 최소 로깅
LOG_LEVEL=WARN
