# api-service (stg) 환경 변수 예시 — 실제 비밀값 금지
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=stg

# DB (stg: prod-like, staging 호스트)
DB_HOST=mariadb.stg.internal
DB_PORT=3306
DB_NAME=rag_api_stg
DB_USER=rag_api
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=redis.stg.internal
REDIS_PORT=6379

# OpenSearch (stg: 보안 활성 https)
OPENSEARCH_URL=https://opensearch.stg.internal:9200

# Retrieval 서비스
RETRIEVAL_SERVICE_URL=http://retrieval.stg.internal:8000

# stg: 표준 로깅
LOG_LEVEL=INFO
