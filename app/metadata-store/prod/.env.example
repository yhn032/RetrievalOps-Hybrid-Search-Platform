# metadata-store (prod) — placeholders only, never commit real secrets
# 운영 환경에서는 아래 비밀값을 secret manager 로 주입한다 (Vault / K8s Secret /
# Docker secret). 가능하면 *_FILE 변수(예: MARIADB_ROOT_PASSWORD_FILE)로
# 파일 경로를 가리키게 하고, 평문 비밀번호는 컨테이너 env 에 남기지 않는다.

# 연결 정보
MARIADB_HOST=metadata-store
MARIADB_PORT=3306

# 스키마 / 계정 (prod: 강한 비밀번호를 secret manager 로 주입)
MARIADB_DATABASE=ragmeta
MARIADB_USER=raguser_prod
# 아래 값은 절대 평문으로 채우지 말 것 — secret manager 주입용 placeholder.
MARIADB_PASSWORD=CHANGE_ME_USE_SECRET_MANAGER
MARIADB_ROOT_PASSWORD=CHANGE_ME_USE_SECRET_MANAGER

# 문자셋
MARIADB_CHARACTER_SET=utf8mb4
MARIADB_COLLATION=utf8mb4_unicode_ci
