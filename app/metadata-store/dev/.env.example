# metadata-store (dev) — placeholders only, never commit real secrets
# 공식 mariadb 이미지가 인식하는 환경변수.

# 연결 정보
MARIADB_HOST=metadata-store
MARIADB_PORT=3306

# 스키마 / 계정 (dev: 단순 placeholder)
MARIADB_DATABASE=ragmeta_dev
MARIADB_USER=raguser
MARIADB_PASSWORD=CHANGE_ME
MARIADB_ROOT_PASSWORD=CHANGE_ME

# 문자셋 (한글/다국어 문서 메타데이터용 utf8mb4)
MARIADB_CHARACTER_SET=utf8mb4
MARIADB_COLLATION=utf8mb4_unicode_ci
