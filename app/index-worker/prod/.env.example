# index-worker (prod) 환경 변수 예시 — 실제 비밀값 금지(시크릿 매니저 권장)
# message-queue(RabbitMQ) 소비 (ADR-0004). worker process — no inbound HTTP port.
SPRING_PROFILES_ACTIVE=prod

# RabbitMQ (색인 작업 소비 — api-service가 발행)
RABBITMQ_HOST=rabbitmq.prod.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=index_worker
RABBITMQ_PASSWORD=CHANGE_ME
# 큐·교환기·DLQ 설계는 M3에서 확정 (ADR-0004)
RABBITMQ_QUEUE=index-jobs

# model-serving (임베딩 REST 호출, ADR-0007)
MODEL_SERVING_URL=https://model-serving.prod.internal:8001

# DB (문서·청크·작업 메타데이터) — MariaDB
DB_HOST=mariadb.prod.internal
DB_PORT=3306
DB_NAME=rag_index
DB_USER=index_worker
DB_PASSWORD=CHANGE_ME

# OpenSearch 색인 대상 (prod: 보안 활성 https)
OPENSEARCH_URL=https://opensearch.prod.internal:9200

# Worker tuning — prod: 튜닝된 batch + info 로그
BATCH_SIZE=64
RETRY_MAX=5
LOG_LEVEL=INFO
