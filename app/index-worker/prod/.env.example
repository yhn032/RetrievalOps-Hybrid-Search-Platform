# index-worker (prod) — placeholder values only, NEVER commit real secrets.
# job queue는 DB work-table 기반 (ADR-0004). worker process — no inbound HTTP port.

# Database (job work-table + metadata) — MariaDB
DB_HOST=mariadb.prod.internal
DB_PORT=3306
DB_NAME=rag_index
DB_USER=index_worker
DB_PASSWORD=CHANGE_ME

# OpenSearch sink (prod: TLS 활성화, security enabled)
OPENSEARCH_URL=https://opensearch.prod.internal:9200

# Embedding model (M1에서 확정)
EMBEDDING_MODEL=CHANGE_ME  # e.g. sentence-transformers/all-MiniLM-L6-v2

# Worker tuning — prod: 튜닝된 batch + info 로그
BATCH_SIZE=64
RETRY_MAX=5
POLL_INTERVAL_SEC=1
LOG_LEVEL=INFO
