# index-worker (stg) — placeholder values only, NEVER commit real secrets.
# job queue는 DB work-table 기반 (ADR-0004). worker process — no inbound HTTP port.

# Database (job work-table + metadata) — MariaDB
DB_HOST=mariadb.stg.internal
DB_PORT=3306
DB_NAME=rag_index_stg
DB_USER=index_worker
DB_PASSWORD=CHANGE_ME

# OpenSearch sink (stg: TLS 활성화)
OPENSEARCH_URL=https://opensearch.stg.internal:9200

# Embedding model (M1에서 확정)
EMBEDDING_MODEL=CHANGE_ME  # e.g. sentence-transformers/all-MiniLM-L6-v2

# Worker tuning — stg: prod 유사 값
BATCH_SIZE=32
RETRY_MAX=5
POLL_INTERVAL_SEC=2
LOG_LEVEL=INFO
