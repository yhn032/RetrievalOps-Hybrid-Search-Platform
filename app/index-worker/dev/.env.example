# index-worker (dev) — placeholder values only, NEVER commit real secrets.
# job queue는 DB work-table 기반 (ADR-0004). worker process — no inbound HTTP port.

# Database (job work-table + metadata) — MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rag_index_dev
DB_USER=index_worker
DB_PASSWORD=CHANGE_ME

# OpenSearch sink (dev: single-node, plain http)
OPENSEARCH_URL=http://localhost:9200

# Embedding model (M1에서 확정)
EMBEDDING_MODEL=CHANGE_ME  # e.g. sentence-transformers/all-MiniLM-L6-v2

# Worker tuning — dev: 작은 batch + 디버그 로그
BATCH_SIZE=8
RETRY_MAX=3
POLL_INTERVAL_SEC=5
LOG_LEVEL=DEBUG
