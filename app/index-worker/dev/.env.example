# index-worker (dev) 환경 변수 예시 — 실제 비밀값 금지(복사 후 채우기)
# message-queue(RabbitMQ) 소비 (ADR-0004). worker process — no inbound HTTP port.
SPRING_PROFILES_ACTIVE=dev

# RabbitMQ (색인 작업 소비 — api-service가 발행)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=index_worker
RABBITMQ_PASSWORD=CHANGE_ME
# 큐·교환기·DLQ 설계는 M3에서 확정 (ADR-0004)
RABBITMQ_QUEUE=index-jobs

# model-serving (임베딩 REST 호출, ADR-0007)
MODEL_SERVING_URL=http://localhost:8001

# DB (문서·청크·작업 메타데이터) — MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rag_index_dev
DB_USER=index_worker
DB_PASSWORD=CHANGE_ME

# OpenSearch 색인 대상 (dev: 단일 노드, 보안 완화)
OPENSEARCH_URL=http://localhost:9200

# Worker tuning — dev: 작은 batch + 디버그 로그
BATCH_SIZE=8
RETRY_MAX=3
LOG_LEVEL=DEBUG
