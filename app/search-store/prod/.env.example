# search-store (OpenSearch) — PROD
# Placeholders only (CHANGE_ME). 실제 비밀은 절대 커밋 금지 — 비밀관리자 주입.

CLUSTER_NAME=rag-search-store-prod

# prod: 멀티노드 — single-node 미사용. 기본 디스커버리 사용.
#   seed_hosts / initial_cluster_manager_nodes 는 M1에서 opensearch.yml 설정.
DISCOVERY_TYPE=

# prod: 큰 heap. 호스트 RAM의 ~50%, 최대 ~32g 미만 권장. -Xms 와 -Xmx 는 동일하게.
OPENSEARCH_JAVA_OPTS=-Xms4g -Xmx4g

# prod: security plugin 활성
DISABLE_SECURITY_PLUGIN=false

# 강력한 admin 비밀번호 placeholder — 대문자/소문자/숫자/특수문자 포함.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 노출 포트
OPENSEARCH_PORT=9200
