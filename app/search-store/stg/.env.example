# search-store (OpenSearch) — STG (prod-like, staging 값)
# Placeholders only (CHANGE_ME). 실제 비밀은 절대 커밋 금지.

CLUSTER_NAME=rag-search-store-stg

# stg: prod 토폴로지 미러 — single-node 미사용. 기본 디스커버리 사용.
#   seed_hosts / initial_cluster_manager_nodes 는 M1에서 opensearch.yml 설정.
DISCOVERY_TYPE=

# stg: 중간 heap (staging 값). -Xms 와 -Xmx 는 동일하게.
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# stg: security plugin 활성 (prod-like)
DISABLE_SECURITY_PLUGIN=false

# staging admin 비밀번호 placeholder — 배포 시 비밀관리자에서 주입.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME

# 노출 포트
OPENSEARCH_PORT=9200
