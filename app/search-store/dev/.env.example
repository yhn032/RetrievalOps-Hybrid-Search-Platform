# search-store (OpenSearch) — DEV
# Placeholders only (CHANGE_ME). 실제 비밀은 절대 커밋 금지.

CLUSTER_NAME=rag-search-store-dev

# dev: 단일 노드
DISCOVERY_TYPE=single-node

# dev: 작은 heap (로컬 자원 절약). -Xms 와 -Xmx 는 동일하게.
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# dev: 로컬 편의를 위해 security plugin 비활성 가능
DISABLE_SECURITY_PLUGIN=true

# security 활성 전환 대비해 키는 유지. plugin 활성 시 필요.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME

# 노출 포트
OPENSEARCH_PORT=9200
