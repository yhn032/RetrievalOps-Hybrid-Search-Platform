{
  "name": "web-ui (dev)",
  "build": {
    "dockerfile": "../dev/Dockerfile",
    "args": { "HOST_UID": "1000", "HOST_GID": "1000" }
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "remoteUser": "app",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      // 언어 확장은 프론트엔드 기술 확정 후 추가한다.
      "extensions": []
    }
  }
}
