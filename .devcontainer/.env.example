# =============================================================================
# Polyagent DevContainer — Configuration (base variant)
# =============================================================================
# 이 파일이 컨테이너 설정의 단일 소스입니다.
# 수정 후: Ctrl+Shift+P → "Rebuild Container"
#
# 다중 인스턴스:
#   cp .env .env.project-b
#   # .env.project-b에서 COMPOSE_PROJECT_NAME, CONTAINER_NAME 변경
#   docker compose --env-file .env.project-b up -d
# =============================================================================

# --- Identity (인스턴스별 고유값) ---
COMPOSE_PROJECT_NAME=polyagent-devcontainer
CONTAINER_NAME=polyagent-dev
IMAGE_NAME=polyagent-devcontainer
IMAGE_TAG=latest

# --- Runtime ---
TZ=UTC

# --- Node.js ---
# 프로젝트용 (비워두면 Node.js 미설치)
# 프로젝트에 Node.js 필요 시 설정. 예: PROJECT_NODE_VERSION=20
PROJECT_NODE_VERSION=

# --- Workspace ---
# 비워두면 .devcontainer 상위 폴더 사용
# Windows: C:\Users\you\project → /c/Users/you/project
HOST_WORKSPACE_PATH=
