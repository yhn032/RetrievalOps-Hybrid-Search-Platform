{
  // ==========================================================================
  // RetrievalOps-Hybrid-Search-Platform Claude Container — Universal Base Template
  // ==========================================================================
  // 표준 근거:
  //   - DevContainer Specification: https://containers.dev/implementors/json_reference/
  //   - Anthropic Claude Code: https://github.com/anthropics/claude-code/tree/main/.devcontainer
  //   - OpenAI Codex CLI: https://github.com/openai/codex
  // ==========================================================================

  "name": "RetrievalOps-Hybrid-Search-Platform Claude Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "retrievalops-hybrid-search-platform-claude",
  "workspaceFolder": "/workspaces",

  // ==========================================================================
  // Container Environment
  // ==========================================================================
  "containerEnv": {
    "DEVCONTAINER": "true",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  },

  "remoteEnv": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0"
  },

  "features": {},

  // ==========================================================================
  // VS Code
  // ==========================================================================
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": null,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "files.encoding": "utf8",
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/node_modules/**": true
        }
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  // ==========================================================================
  // Lifecycle
  // ==========================================================================
  "postCreateCommand": "/usr/local/bin/setup-env.sh",
  "postStartCommand": "git config core.filemode false 2>/dev/null || true",
  "waitFor": "postCreateCommand",

  // ==========================================================================
  // User & Process
  // ==========================================================================
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "init": true,
  "shutdownAction": "stopCompose",

  // ==========================================================================
  // Mounts
  // SSH: 호스트 키 바인드 (git push/pull)
  // 인증/히스토리 영속 볼륨(claude-config·codex-config·command-history)은
  // docker-compose.yml에서 정의 — plain `docker compose up`과 VS Code가
  // 동일 named volume을 공유하도록 여기서 재정의하지 않음.
  // ==========================================================================
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
  ]
}
